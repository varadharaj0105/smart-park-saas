# ============================================
# Smart Park SaaS — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your real .env to git
# ============================================

# MySQL / Production DB (Railway, PlanetScale, etc.)
DB_HOST=your-db-host.example.com
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=smart_park_saas

# JWT Secret — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# Port the backend listens on
PORT=5000
